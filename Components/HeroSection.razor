<section id="hero" class="hero-section">
    <div class="hero-bg-glow glow-1"></div>
    <div class="hero-bg-glow glow-2"></div>
    <div class="container hero-container">
        <div class="hero-body">
            <p class="hero-eyebrow"><span class="pulse-dot"></span>Open to new opportunities</p>
            <h1 class="hero-name">Rodrigo Santiago</h1>
            <h2 class="hero-title">Architect &amp; Software Engineer</h2>
            <p class="hero-subtitle">AWS &nbsp;&middot;&nbsp; Azure &nbsp;&middot;&nbsp; SAP BTP &nbsp;&middot;&nbsp; .NET &nbsp;&middot;&nbsp; Full Stack</p>

            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-n">20+</span>
                    <span class="stat-l">Years Experience</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-n">3</span>
                    <span class="stat-l">Cloud Platforms</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-n">10+</span>
                    <span class="stat-l">Enterprise Clients</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-n">2</span>
                    <span class="stat-l">Native Languages</span>
                </div>
            </div>

            <div class="hero-actions">
                <a href="mailto:@ProfileData.Email" class="hero-btn">@ProfileData.Email</a>
                <a href="@ProfileData.LinkedInUrl" target="_blank" rel="noopener" class="hero-btn hero-btn-linkedin">LinkedIn</a>
                <span class="hero-location">&#128205; Austin, TX &nbsp;&middot;&nbsp; US Citizen</span>
            </div>
        </div>
    </div>
    <a href="#about" class="hero-scroll-hint">&#8595; Scroll</a>
</section>
